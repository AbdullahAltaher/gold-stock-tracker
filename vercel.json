{
  "rewrites": [
    {
      "source": "/api/metals/(.*)",
      "destination": "https://api.metals.live/$1"
    },
    {
      "source": "/api/yahoo/(.*)",
      "destination": "https://query1.finance.yahoo.com/$1"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}