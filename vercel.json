{
  "rewrites": [
    {
      "source": "/api/metals/(.*)",
      "destination": "https://api.metals.live/$1"
    },
    {
      "source": "/api/yahoo/(.*)",
      "destination": "https://query1.finance.yahoo.com/$1"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/api/yahoo/(.*)",
      "headers": [
        { "key": "User-Agent", "value": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36" },
        { "key": "Accept", "value": "application/json" }
      ]
    }
  ]
}